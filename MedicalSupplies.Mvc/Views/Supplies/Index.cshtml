@model List<SupplyListItemViewModel>
@{
    ViewData["Title"] = "Medical Supplies Catalog";
    var totalItems = Model.Count;
}
<div class="page-header">
    <div>
        <h2 class="page-title">Danh mục vật tư y tế</h2>
        <p class="page-description">Danh sách vật tư, thiết bị y tế của kho.</p>
    </div>
    <div>
        <a class="btn btn-primary" href="/Supplies/Stats">
            Xem thống kê kho
        </a>
    </div>
</div>

<div class="info-panel">
    <strong>Tổng số vật tư:</strong> @totalItems
</div>

@if (Model.Count == 0)
{
    <p>Chưa có vật tư nào trong hệ thống.</p>
}
else
{
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Mã vật tư</th>
                <th>Tên vật tư</th>
                <th>Nhóm</th>
                <th>Nhà cung cấp</th>
                <th>Đơn giá</th>
                <th>Số lượng</th>
                <th>Giá trị tồn kho</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@item.Supplier</td>
                    <td>@item.PriceText</td>
                    <td>@item.Quantity</td>
                    <td>@item.InventoryValueText</td>
                    <td>
                        <span class="@item.StockStatusClass">
                            @item.StockStatus
                        </span>
                    </td>
                    <td>
                        <a href="/Supplies/Detail/@item.Id">Xem</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
<p class="mt-4">
    <a class="btn btn-light" href="/">Quay lại trang chủ</a>
</p>